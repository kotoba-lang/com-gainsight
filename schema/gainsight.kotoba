// Gainsight clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace gainsight {

    entity Ticket {
        id: string @unique
        subject: string
        requesterId: string
        priority: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Survey {
        id: string @unique
        title: string
        type: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Response {
        id: string @unique
        surveyId: string
        respondentId: string
        score: integer
        submittedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Account {
        id: string @unique
        name: string
        healthScore: float
        arr: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Conversation {
        id: string @unique
        accountId: string
        channel: string
        sentiment: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Contact {
        id: string @unique
        email: string
        firstName: string
        lastName: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
